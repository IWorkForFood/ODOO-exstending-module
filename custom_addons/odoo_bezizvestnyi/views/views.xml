  <record id="view_order_form_inherit_odoo_bezizvestnyi" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.odoo.bezizvestnyi</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>  <!-- ← вот эта ссылка на оригинальный view -->
        <field name="arch" type="xml">

            <!-- Вставляем поле "Ответственный за выдачу товара" строго после partner_id в блоке "Customer" -->
            <xpath expr="//group[@name='partner_details']/field[@name='partner_id']" position="after">
                <field name="responsible_employee_id" required="1"/>
            </xpath>

            <xpath expr="//field[@name='responsible_employee_id']" position="after">
                <field name="new_field_manual_change" invisible="1" force_save="1"/>
                <field name="new_field"
                       readonly="state != 'draft'"
                       invisible="state == 'sale'"/>
            </xpath>

        </field>
    </record>


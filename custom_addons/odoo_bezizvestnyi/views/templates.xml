<odoo>
    <data>
        <template id="report_saleorder_document_inherit_odoo_bezizvestnyi" inherit_id="sale.report_saleorder_document">
            <xpath expr="//table[contains(@class, 'o_main_table')]" position="before">
                <div class="mb-3">
                    <t t-if="doc.new_field">
                        <strong>New Field:</strong>
                        <span t-field="doc.new_field"/>
                    </t>
                    <t t-else="">
                        <strong>Поле New Field пустое!!!</strong>
                    </t>
                </div>
            </xpath>
        </template>

